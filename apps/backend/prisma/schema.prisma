generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PRINCIPAL
}

enum FaceStatus {
  NOT_ADDED
  ADDED
  RESCAN
}

model User {
  id           String   @id @default(uuid())
  userCode     String @unique
  role         Role
  mobileNumber String   @unique
  email        String?  @unique
  passwordHash String
  status       String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student?
  teacher      Teacher?
}

model School {
  id        String   @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  geoRadius Float

  standards Standard[]

  createdAt DateTime @default(now())
}

model Standard {
  id       String  @id @default(uuid())
  name     String

  school   School  @relation(fields: [schoolId], references: [id])
  schoolId String

  sections Section[]
}

model Section {
  id         String   @id @default(uuid())
  name       String

  standard   Standard @relation(fields: [standardId], references: [id])
  standardId String

  students Student[]
  teachers TeacherSection[]
}

model Student {
  id         String   @id @default(uuid())

  user       User     @relation(fields: [userId], references: [id])
  userId     String   @unique

  section    Section  @relation(fields: [sectionId], references: [id])
  sectionId  String

  rollNumber Int
  faceStatus FaceStatus @default(NOT_ADDED)

  createdAt  DateTime @default(now())

  @@unique([sectionId, rollNumber])
}

model Teacher {
  id     String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  sections TeacherSection[]
}

model TeacherSection {
  id        String  @id @default(uuid())

  teacher   Teacher @relation(fields: [teacherId], references: [id])
  teacherId String

  section   Section @relation(fields: [sectionId], references: [id])
  sectionId String

  @@unique([teacherId, sectionId])
}